# Loaded *before* `.env` by npm scripts and next.config (dotenv-cli: first file wins for duplicates).
# Keeps DATABASE_URL / REDIS_URL aligned with docker-compose.yml.
# Remove this file if you use a non-Docker Postgres/Redis and set URLs only in `.env`.
DATABASE_URL=postgresql://jobradar:jobradar@localhost:5432/jobradar
REDIS_URL=redis://localhost:6379
