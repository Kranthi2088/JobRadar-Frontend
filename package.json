{
  "name": "jobradar-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "prisma generate --schema=packages/db/prisma/schema.prisma",
    "dev": "turbo dev --filter=@jobradar/web",
    "dev:all": "turbo dev",
    "dev:web": "turbo dev --filter=@jobradar/web",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo test",
    "db:generate": "dotenv -e .env -e docker/compose.override.env -- npx prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:push": "dotenv -e .env -e docker/compose.override.env -- npx prisma db push --schema=packages/db/prisma/schema.prisma",
    "db:migrate": "dotenv -e .env -e docker/compose.override.env -- npx prisma migrate dev --schema=packages/db/prisma/schema.prisma",
    "db:seed": "dotenv -e .env -e docker/compose.override.env -- npx tsx packages/db/prisma/seed.ts",
    "db:backfill-listing-keys": "dotenv -e .env -e docker/compose.override.env -- npx tsx packages/db/prisma/backfill-listing-keys.ts",
    "db:studio": "dotenv -e .env -e docker/compose.override.env -- npx prisma studio --schema=packages/db/prisma/schema.prisma",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
