generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  free
  pro
  teams
}

enum NotificationChannel {
  web_push
  mobile_push
  email
  telegram
}

enum EmailMode {
  instant
  daily
  none
}

enum ATSType {
  greenhouse
  lever
  ashby
  workday
  rippling
  custom
  playwright
  /// Microsoft careers PCSX JSON API (apply.careers.microsoft.com/api/pcsx/search)
  microsoft_pcsx
  /// Meta Careers GraphQL captured from browser-network responses.
  meta_graphql
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  /// bcrypt hash for email/password accounts; null for OAuth-only users
  passwordHash  String?
  plan          Plan      @default(free)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  watchlists        Watchlist[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  preferences       UserPreferences?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Employer — job ingest is driven by `sources` (see CompanySource), not a single ATS field.
model Company {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  logoUrl           String?
  /// When set, that CompanySource is tried first on the next poll (sticky preference). Unique so a source is preferred by at most one company (itself).
  preferredSourceId String? @unique
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  watchlists      Watchlist[]
  jobs            Job[]
  sources         CompanySource[]              @relation("CompanySources")
  preferredSource CompanySource?             @relation("PreferredCompanySource", fields: [preferredSourceId], references: [id], onDelete: SetNull)

  @@map("companies")
}

/// One ingest endpoint (ATS API, careers HTML, etc.) per company. Lower `priority` = tried earlier when merging.
model CompanySource {
  id            String    @id @default(cuid())
  companyId     String
  priority      Int       @default(0)
  atsType       ATSType
  endpoint      String
  isActive      Boolean   @default(true)
  lastSuccessAt DateTime?
  lastError     String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company       Company @relation("CompanySources", fields: [companyId], references: [id], onDelete: Cascade)
  preferredFor  Company? @relation("PreferredCompanySource")
  jobs          Job[]

  @@index([companyId, priority])
  @@map("company_sources")
}

model Watchlist {
  id                      String   @id @default(cuid())
  userId                  String
  companyId               String
  roleKeyword             String
  /// How often the worker should poll this company’s ATS for this watch (seconds). Clamped in API.
  pollingIntervalSeconds  Int      @default(300)
  locationFilter          String?
  seniorityFilter         String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, roleKeyword])
  @@map("watchlists")
}

model Job {
  id              String   @id @default(cuid())
  companyId       String
  companySourceId String?
  /// Stable dedupe across sources: hash of normalized listing URL. Nullable only until `npm run db:backfill-listing-keys` runs after migrating old rows.
  listingKey      String?
  /// Raw id from the ATS adapter that won this row (after merge).
  externalId      String
  title           String
  url             String
  team            String?
  location        String?
  seniority       String?
  /// When the employer/ATS says the listing was published or last updated (best effort).
  postedAt        DateTime?
  detectedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companySource CompanySource? @relation(fields: [companySourceId], references: [id], onDelete: SetNull)
  notifications Notification[]
  applications  Application[]

  @@unique([companyId, listingKey])
  @@index([companyId, detectedAt])
  @@map("jobs")
}

model Application {
  id        String   @id @default(cuid())
  userId    String
  jobId     String
  appliedAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@map("applications")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  jobId     String
  channel   NotificationChannel
  sentAt    DateTime            @default(now())
  clickedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@map("notifications")
}

model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  type     String // web, ios, android
  token    String?
  endpoint String? @db.Text
  p256dh   String?
  auth     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model UserPreferences {
  id              String    @id @default(cuid())
  userId          String    @unique
  quietHoursStart String?   // HH:mm format
  quietHoursEnd   String?   // HH:mm format
  emailMode       EmailMode @default(instant)
  timezone        String    @default("UTC")
  telegramEnabled Boolean   @default(false)
  telegramChatId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}
