# Database — needed for auth, watchlist, and job feed (not for `npm run dev` UI shell alone).
# Use a hosted Postgres (Neon, Supabase, etc.) or `docker compose up -d` if you use Docker.
DATABASE_URL="postgresql://jobradar:jobradar@localhost:5432/jobradar"

# Redis — only required for the worker (`npm run dev:all` or `dev:worker`)
REDIS_URL="redis://localhost:6379"

# After `npm install`, install Playwright’s browser once (used by careers fallback scraping):
# npx playwright install chromium

# Optional: cap Microsoft PCSX API pagination (default 300 jobs per poll)
# MICROSOFT_PCSX_MAX_JOBS=300

# Web app URL (shown in worker redirect if you open the worker port by mistake)
WEB_APP_URL="http://localhost:3000"

# Auth (NextAuth.js)
# Email/password sign-up uses POST /api/auth/register; set Google OAuth for "Continue with Google".
# Production: use the full URL with scheme, e.g. https://your-app.vercel.app (not a bare hostname).
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Local dev sign-in (creates user in DB; never enable in production)
# Must be exactly this name (all caps, underscores). Not: enableDevLocalAuth
ENABLE_DEV_LOCAL_AUTH="false"

# Allow POST /api/dev/reset — deletes all jobs + clears worker Redis cache (local testing only)
ENABLE_DEV_DATA_RESET="false"
# Optional: if set, local sign-in requires this value in the "Dev secret" field
# DEV_LOCAL_AUTH_SECRET="change-me"

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@jobradar.app"

# Email (Resend)
RESEND_API_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Sentry
SENTRY_DSN=""

# Worker — throttled polling (see apps/worker/src/poller.ts)
# POLL_SCHEDULER_TICK_MS: how often the scheduler checks what to poll (default 10000)
# MAX_POLLS_PER_TICK: ATS HTTP requests per tick—keep 1 on a laptop
POLL_SCHEDULER_TICK_MS=10000
MAX_POLLS_PER_TICK=1
WORKER_PORT=3010
